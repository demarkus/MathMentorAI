NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Required to provision profile rows (bypasses RLS). Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional, server-only (read only in src/lib/ai/). Enables AI-guided hints and
# worked solutions on wrong answers (practice + diagnostic review); when unset,
# learners get the seeded hints and solution_steps.
ANTHROPIC_API_KEY=your-anthropic-api-key
